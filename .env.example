# CNAMM Assessment Email Configuration
# Copy this file to .env and fill in your values

# SMTP Configuration
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-username
SMTP_PASSWORD=your-password
SMTP_FROM_EMAIL=noreply@example.com

# Note: Never commit your actual .env file with credentials to the repository